{
  "name": "get-note-sync",
  "version": "1.0.0",
  "description": "Obsidian plugin that syncs Get notes via OpenAPI.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "check": "tsc -noEmit -skipLibCheck",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "get",
    "biji"
  ],
  "author": "FoxFini",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.2",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.3",
    "obsidian": "latest",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3"
  }
}
